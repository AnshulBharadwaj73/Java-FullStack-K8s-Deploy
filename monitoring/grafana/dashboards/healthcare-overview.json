{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Services Up",
      "datasource": "Prometheus",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(up{job=\"spring-boot\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } }
    },
    {
      "type": "stat",
      "title": "Total RPS",
      "datasource": "Prometheus",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count[1m]))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "5xx Error Rate",
      "datasource": "Prometheus",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } }
    },
    {
      "type": "stat",
      "title": "Firing Alerts",
      "datasource": "Prometheus",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "sum(ALERTS{alertstate=\"firing\"})", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Requests/sec by service",
      "datasource": "Prometheus",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "sum by (service) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{service}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "P95 latency by service",
      "datasource": "Prometheus",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "{{service}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "JVM heap used / max",
      "datasource": "Prometheus",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "sum by (service) (jvm_memory_used_bytes{area=\"heap\"}) / sum by (service) (jvm_memory_max_bytes{area=\"heap\"})", "legendFormat": "{{service}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "type": "timeseries",
      "title": "GC pause time (s/s)",
      "datasource": "Prometheus",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "sum by (service) (rate(jvm_gc_pause_seconds_sum[5m]))", "legendFormat": "{{service}}", "refId": "A" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["healthcare", "spring-boot"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Healthcare Services Overview",
  "uid": "healthcare-overview",
  "version": 1,
  "weekStart": ""
}
